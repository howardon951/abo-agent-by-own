{
  "name": "abo-agent-by-own",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n web,worker -c auto \"pnpm dev:web\" \"pnpm dev:worker\"",
    "dev:web": "next dev",
    "dev:worker": "node --env-file=.env.local --import tsx src/worker/index.ts",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "worker": "pnpm dev:worker",
    "test:backend": "node --import tsx --test tests/backend/**/*.test.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.56.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
